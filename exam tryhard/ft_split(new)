#include <stdio.h>
#include <stdlib.h>

int	ft_is_sep(char c, char *charset) // nb separateurs dans str
{
	int	i;

	i = 0;
	while (charset[i])
	{
		if (c == charset[i]) // si un char = un separateur
			return (1);
		i++;
	}
	return (0);
}

int	ft_nb(char *str, char *charset) // nb mots dans str
{
	int	i;
	int	nb;

	i = 1; // on commence a str[i-1] pour separateur donc l'index se decale
	nb = 1;
	while (str[i])
	{
		if (ft_is_sep(str[i], charset) && !(ft_is_sep(str[i - 1], charset)))
			nb++; // c'est quil faut mettre un mot
		i++;
	}
	if (ft_is_sep(str[i - 1], charset))
		nb--;
	return (nb);
}

int	ft_word_len(char *str, char *charset) // definit cmt trouver longueur des mots
{
	int	i;

	i = 0;
	while (str[i] && !(ft_is_sep(str[i], charset)))
       	// tant que str est parcouru & separateurs au mauvais endroit
		i++;
	return i;
}

char	*ft_new_word(char *str, char *charset) // alloc des mots
{
	int	i;
	int	word_len;
	char	*word;

	i = 0;
	word_len = ft_word_len(str, charset); // la taille des mots definie dans ft_word_len
	word = malloc((sizeof(char)) * (word_len + 1));
	// alloc des mots selon leur taille+1 (car tjr mot NULL a la fin)
	while (i < word_len)
	// tant que str est parcouru & separateurs au mauvais endroit
	{
		word[i] = str[i];
		i++;
	}
	word[i] = 0;
	return (word);
}

char	**ft_split(char *str, char *charset)
{
	int	i;
	int	j; // index parcourant strs
	char	**strs;
	int	nb;
	
	i = 0;
	j = 0;
	if (str[0] == '\0') // si la premiere variable est nulle
	{
		strs = malloc(sizeof(char *)); // on attribue a strs une alloc pour le 'vide' de str[0]
		strs[0] = NULL; // valeur assignee a NULL 
		return (strs);
	}		
	nb = ft_nb(str, charset); // nb de mots a retrouver dans ft_nb
	strs = malloc((sizeof(char *)) * (nb + 1)); 
	// alloc de strs et toutes ses variables sauf str[0] (d'ou le -1)
	while (i < nb)
	{
		while (str[j] && ft_is_sep(str[j], charset)) // tant que parcours de strs et separateurs
			j++;
		strs[i] = ft_new_word(&(str[j]), charset); // parcours de strs = ft alloc des mots
		i++;
		while (str[j] && !(ft_is_sep(str[j], charset))) // tant que parcours de strs ms separateurs places autrement
			j++;
	}
	strs[i] = NULL; // on arrete tout  
	return (strs);
}

int	main(void)
{
	char	*str = "pomme, banane, poire, mure, abricot";
	char	*charset = " ";
	char	**result;

	result = ft_split(str, charset);
	int i = 0;
	printf("%s\n", str);
	while (result[i])
	{
		printf("%s\n", result[i]);
		free(result[i]);
		i++;
	}
	free(result);
	return (0);
}
